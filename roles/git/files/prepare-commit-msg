#!/bin/sh
# Automatically add Signed-off-by line.
# Skip merge and squash commits — they already carry a full message.
case "$2" in
  merge|squash) exit 0 ;;
esac

NAME=$(git config user.name)
EMAIL=$(git config user.email)
SOB="Signed-off-by: $NAME <$EMAIL>"

grep -qsF "$SOB" "$1" || printf '\n%s\n' "$SOB" >> "$1"
